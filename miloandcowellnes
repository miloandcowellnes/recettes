<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Milo & Co. — 15 Recettes Gourmandes</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #F5F0E8;
    color: #5C4A3A;
    max-width: 680px;
    margin: 0 auto;
    padding: 0 0 40px 0;
  }

  .header {
    background: linear-gradient(135deg, #8FA89A 0%, #6B8C7D 100%);
    padding: 36px 24px 28px;
    text-align: center;
    color: white;
  }
  .header .logo-top {
    width: 180px;
    margin: 0 auto 16px;
    display: block;
    filter: brightness(0) invert(1);
  }
  .header .divider { width: 60px; height: 2px; background: rgba(255,255,255,0.5); margin: 0 auto 16px; }
  .header .title-main {
    font-size: 20px;
    font-weight: 700;
    color: white;
    margin-bottom: 6px;
  }
  .header .title-sub {
    font-size: 12px;
    color: rgba(255,255,255,0.85);
    font-style: italic;
  }

  .intro {
    background: white;
    padding: 20px 24px;
    text-align: center;
    font-size: 13px;
    line-height: 1.7;
    color: #8B6F5E;
    border-bottom: 1px solid #EDE8DE;
  }

  .category { margin: 24px 16px 0; position: relative; }
  .category-header {
    background: #6B8C7D;
    color: white;
    padding: 10px 18px;
    border-radius: 10px 10px 0 0;
    font-size: 14px;
    font-weight: 700;
  }

  .recipe-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: #C5D4CD;
    border: 1px solid #C5D4CD;
    border-top: none;
    border-radius: 0 0 10px 10px;
    overflow: hidden;
  }
  @media (max-width: 480px) { .recipe-grid { grid-template-columns: 1fr; } }

  .recipe-card {
    background: #FAF7F2;
    padding: 16px 16px 44px 16px;
    position: relative;
  }
  .recipe-card:nth-child(even) { background: #F0EDE8; }

  .recipe-emoji { font-size: 22px; margin-bottom: 6px; display: block; }
  .recipe-name {
    font-size: 13px;
    font-weight: 700;
    color: #5C4A3A;
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid #C5D4CD;
  }
  .label {
    font-size: 10px;
    font-weight: 700;
    color: #6B8C7D;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
    margin-top: 8px;
  }
  .recipe-text {
    font-size: 12px;
    color: #5C4A3A;
    line-height: 1.6;
  }
  .tip {
    font-size: 11px;
    color: #8FA89A;
    font-style: italic;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px dashed #C5D4CD;
  }
  .logo-watermark {
    position: absolute;
    bottom: 8px;
    right: 10px;
    width: 60px;
    opacity: 0.15;
  }

  .footer {
    text-align: center;
    padding: 32px 24px 16px;
  }
  .footer .logo-footer {
    width: 130px;
    margin: 0 auto 10px;
    display: block;
    opacity: 0.75;
  }
  .footer .tagline {
    font-size: 12px;
    color: #8FA89A;
    font-style: italic;
  }
</style>
</head>
<body>

<div class="header">
